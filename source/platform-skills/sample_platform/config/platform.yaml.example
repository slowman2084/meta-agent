# Sample Platform — 配置模板
# 复制为 platform.yaml 并填入实际值

platform:
  name: sample-platform
  api_endpoint: https://api.example.com/v1
  api_key: YOUR_API_KEY_HERE    # 或使用环境变量 ${SAMPLE_PLATFORM_API_KEY}
  model: gpt-4o                  # 默认模型
  timeout: 120                   # 单条用例超时（秒）
  max_concurrent: 3              # 最大并发数

# 可选：模型映射（适配不同平台的模型命名）
model_mapping:
  gpt-4o: gpt-4o-2024-08-06
  claude-sonnet-4: claude-sonnet-4-20250514
