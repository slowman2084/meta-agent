# ===================================
# Python 相关
# ===================================
# 虚拟环境
venv/
.venv/
env/
.env/

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 分发/打包
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ===================================
# IDE Agent 目录（由 install.py 动态生成）
# ===================================
.claude/
.codebuddy/
.cursor/

# ===================================
# IDE 相关
# ===================================
# VS Code
.vscode/

# JetBrains
.idea/

# ===================================
# 系统文件
# ===================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# nohup 输出（含测试日志，可能包含内部 URL）
nohup.out

# ===================================
# 项目特定：临时文件和测试产物
# ===================================
# 各 Agent 的临时运行目录（测试日志、中间产物）
**/tmp/

# 根目录临时脚本和配置（可能含 API Key、本地路径等敏感信息）
tmp_*.py
tmp_*.yaml
tmp_*.json
EXPLORATION_REPORT_*.md

# source/skills/ 下的符号链接（指向外部项目）
source/skills/ppt-hours

# 废弃/临时脚本目录（含个人路径等敏感信息）
scripts/deprecated/

# 临时/一次性脚本（业务特定，不纳入版本控制）
scripts/analyze_*.py
scripts/batch_*.py
scripts/check_*.py
scripts/extract_*.py
scripts/fix_*.py
scripts/list_*.py
scripts/refactor_*.py
scripts/run_*.py

# 运行时状态文件（本地上下文）
.agent_factory_context.json

# IDE 本地配置（可能包含个人偏好或权限设置）
.claude/settings.local.json
.codebuddy/settings.local.json

# source/ 目录管理策略
# 默认排除所有，只纳入版本控制的子目录：
#   source/agents/meta-* — 工厂基础设施 Agent
#   source/agents/歌词生成系统/ — 创建→测试→迭代全流程 Sample
#   source/skills/meta-* — Meta Skills（工厂核心）
#   source/platform-skills/ — 平台 Skill（执行环境封装）
#   source/hooks/        — 钩子脚本
source/*
!source/agents/
!source/agents/meta-*/
!source/agents/歌词生成系统/
!source/skills/
!source/skills/meta-*/
!source/platform-skills/
!source/rules/
!source/hooks/

# source/skills/ 下的业务 Skill（非 meta-*）不纳入版本控制
# 包含企业隐私或内部业务数据
source/skills/cls-query/
source/skills/cls-query-skill/
source/skills/plan-mindmap/
source/skills/platform_react_runner/
source/skills/review-delivery/
source/skills/review-sync/

# source/agents/ 下的业务 Agent（非 meta-* 且非 Sample）不纳入版本控制
source/agents/cls-log-agent/
source/agents/塑普歌词生成器/
source/agents/说唱生成系统/

# 工作日志（本地迭代记录，不纳入版本控制）
工作日志/

# docs/ 目录（设计文档，本地参考，不纳入版本控制）
docs/

# 根目录多余的 markdown（只保留 README*.md、CONTRIBUTING.md、CLAUDE.md、CODEBUDDY.md、AGENTS.md、SETUP.md）
ANALYSIS_SUMMARY*.md
CODE_OF_CONDUCT.md
DOCUMENTATION_AUDIT_INDEX*.md
EVIDENCE_EXAMPLES*.md
PROJECT_STRUCTURE.md
README_GAP_ANALYSIS*.md
case_*_eval_result.md

# 备份文件
**/bak/
**/*.bak
**/*.bak_*
**/*.bak2_*

# 参考资料目录（内部业务文档）
**/references/

# Office 文档（可能包含内部业务信息）
*.docx
*.xlsx
*.pptx

# ===================================
# 压缩包/大文件
# ===================================
*.zip
*.tar.gz
*.rar
*.7z

# ===================================
# 日志文件
# ===================================
*.log
logs/

# ===================================
# 环境变量文件（敏感信息）
# ===================================
.env
.env.*
!.env.example

# MCP 配置文件（包含 API 密钥）
.mcp.json
source/*/.mcp.json

# 平台配置文件（包含 API 密钥）
.cursor/skills/*/config/*.yaml
.codebuddy/skills/*/config/*.yaml
.claude/skills/*/config/*.yaml
**/observable_platform.yaml
**/platform.yaml

# cls-log-agent 配置文件（包含敏感密钥）
source/agents/cls-log-agent/config/*.yaml
!source/agents/cls-log-agent/config/*.example

# ===================================
# 其他
# ===================================
# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# mypy 缓存
.mypy_cache/

# pytest 缓存
.pytest_cache/

# coverage 报告
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
scripts/hooks/.test_context
